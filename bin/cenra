#!/bin/bash

CMD=$1

case "$CMD" in
  help)
    echo ""
    echo "🚀 cenra - central control CLI"
    echo ""
    echo "Usage:"
    echo "In progress..."
    echo "Future:"
    echo "  cenra device ..."
    echo "  cenra account ..."
    echo ""
    ;;
  *)
    echo "Unknown command. Try: cenra help"
    ;;
esac
