#!/bin/bash

CMD=$1

case "$CMD" in

# -------------------------
# HELP
# -------------------------
help)
echo
echo "╭──────────────────────────────╮"
echo "│      C E N R A • v1.0.0      │"
echo "╰──────────────────────────────╯"
echo
echo "Commands:"
echo "  cenra"
echo "    ├── help ........... Show help"
echo "    ├── update ......... Update CLI"
echo "    └── users ........... Manage users"
echo
echo "Tip: cenra update"
echo
;;

# -------------------------
# UPDATE (твоя логика сохранена)
# -------------------------
update)
echo "Checking for updates..."

cd ~/cenra || exit 1

git fetch origin

LOCAL=$(git rev-parse HEAD)
REMOTE=$(git rev-parse origin/main)

if [ "$LOCAL" = "$REMOTE" ]; then
    echo "cenra is already up to date"
    exit 0
fi

echo "Update found. Pulling changes..."

git pull origin main

echo "Reinstalling cenra..."
bash install.sh
;;

# -------------------------
# USERS (НОВЫЙ МОДУЛЬ)
# -------------------------
users)
  if [ -f ~/cenra/modules/users/users.sh ]; then
    bash ~/cenra/modules/users/users.sh
  else
    echo "users module not installed"
    echo "run: cenra update or reinstall cenra"
  fi
;;

# -------------------------
# DEFAULT
# -------------------------
*)
echo "Unknown command"
echo "Try: cenra help"
;;

esac
